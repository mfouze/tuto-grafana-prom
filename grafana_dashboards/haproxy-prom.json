    {
      "title": "Nodes (UP / DOWN)",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "title": "Serveurs UP",
      "description": "Nombre de séries avec label state=\"UP\" à 1 (un serveur peut apparaître sur plusieurs proxies).",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(haproxy_server_status{proxy=~\"$proxy\",cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\",state=\"UP\"})",
          "legendFormat": "UP",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 6
      }
    },
    {
      "title": "Serveurs (total)",
      "description": "Nombre de couples (proxy, server) — un même nom de server sur deux proxies compte deux fois.",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "count(sum by (proxy, server) (haproxy_server_status{proxy=~\"$proxy\",cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}))",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 6
      }
    },
    {
      "title": "État par serveur (label state)",
      "description": "Une série par combinaison proxy / server / state. La valeur vaut 1 pour l’état actif.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "haproxy_server_status{proxy=~\"$proxy\",cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}",
          "legendFormat": "{{proxy}} / {{server}} / {{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 25,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 16,
        "x": 8,
        "y": 6
      }
    },
