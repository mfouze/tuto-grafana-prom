              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "green",
                "value": 60
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 15,
        "y": 1
      }
    },
