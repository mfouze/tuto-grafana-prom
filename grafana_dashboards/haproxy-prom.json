    {
      "title": "Server Status",
      "type": "table",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "haproxy_server_status{proxy=~\"$proxy\",cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"} == 1",
          "legendFormat": "",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 17
      },
      "description": "Une ligne par état actif : colonnes **proxy**, **server**, **state** (métrique avec label state : UP, DOWN, DRAIN, etc.).",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": false
            },
            "indexByName": {},
            "renameByName": {
              "proxy": "Proxy",
              "server": "Serveur (node)",
              "state": "État",
              "Value": "Actif (1)"
            }
          }
        }
      ]
    },
    {
      "title": "Server Status — historique",
      "description": "Historique : une courbe par combinaison proxy / server / state (valeur 0 ou 1).",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "haproxy_server_status{proxy=~\"$proxy\",cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}",
          "legendFormat": "{{proxy}} / {{server}} / {{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 25,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 16,
        "x": 8,
        "y": 17
      }
    },
    {
      "title": "Historique des changements d'état",
      "description": "Nombre de **bascules** d'état administratif dans la fenêtre glissante (5 min), par couple (proxy, serveur). À chaque transition, deux séries `state` passent 0↔1 : `sum(changes) / 2` approxime le nombre de changements.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (proxy, server) (changes(haproxy_server_status{proxy=~\"$proxy\",cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}[5m])) / 2",
          "legendFormat": "{{proxy}} / {{server}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "short",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "fillOpacity": 60,
            "barAlignment": 0,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 23
      }
