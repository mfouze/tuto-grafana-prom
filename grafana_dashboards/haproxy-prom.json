      },
      "targets": [
        {
          "expr": "haproxy_process_current_session_rate{cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}",
          "legendFormat": "sess/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
