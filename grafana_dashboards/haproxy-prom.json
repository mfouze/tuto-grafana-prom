      },
      "targets": [
        {
          "expr": "haproxy_process_current_connections{cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}",
          "legendFormat": "Connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "red",
                "value": 400
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 6,
        "y": 1
      }
    },
    {
      "title": "Max Connections",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "haproxy_process_max_connections{cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}",
          "legendFormat": "Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 9,
        "y": 1
      }
    },
    {
      "title": "Connection Rate",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(haproxy_process_connections_total{cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}[5m])",
          "legendFormat": "conn/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 12,
        "y": 1
      }
    },
    {
      "title": "Idle Time %",
      "type": "gauge",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "haproxy_process_idle_time_percent{cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}",
          "legendFormat": "Idle %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
