{
  "id": null,
  "uid": "haproxy-standalone",
  "title": "HAProxy Standalone",
  "description": "HAProxy monitoring — backends, proxies, server state (label state).",
  "tags": [
    "haproxy",
    "transactis"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "label": "Cluster",
        "query": "label_values(haproxy_backend_status, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {}
      },
      {
        "name": "environment",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "label": "Environment",
        "query": "label_values(haproxy_backend_status{cluster=~\"$cluster\"}, environment)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {}
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "label": "Instance",
        "query": "label_values(haproxy_backend_status{cluster=~\"$cluster\",environment=~\"$environment\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {}
      },
      {
        "name": "proxy",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "label": "Proxy",
        "query": "label_values(haproxy_backend_status{cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}, proxy)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "HAProxy Overview",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "title": "Uptime",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "haproxy_process_uptime_seconds{cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 1
      }
    },
    {
      "title": "Threads",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "haproxy_process_nbthread{cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}",
          "legendFormat": "Threads"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 3,
        "y": 1
      }
    },
    {
      "title": "Current Connections",
