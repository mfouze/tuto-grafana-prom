        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "haproxy_process_pool_used_bytes{cluster=~\"$cluster\",environment=~\"$environment\",instance=~\"$instance\"}",
          "legendFormat": "Used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
