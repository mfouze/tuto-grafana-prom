# Configuration Kafka - Exemple de fichier .env
# Copiez ce fichier vers .env et remplissez les valeurs
#   cp env.example .env && vim .env

# =============================================================================
# Connexion au cluster (requis)
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=m9k-a8195-dev-kafka-paris-hml-1.sp2-hp.transactis.fr:9094,m9k-a8195-dev-kafka-paris-hml-2.sp2-hp.transactis.fr:9094,m9k-a8195-dev-kafka-paris-hml-3.sp2-hp.transactis.fr:9094

# =============================================================================
# Authentification SASL (requis)
# =============================================================================
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_USERNAME=app-producer
KAFKA_PASSWORD=MOT_DE_PASSE_VAULT

# =============================================================================
# SSL / TLS - Certificats (montes via docker -v)
# =============================================================================
# Truststore (certificat CA Transactis)
KAFKA_SSL_TRUSTSTORE=/app/certs/truststore.jks
KAFKA_SSL_TRUSTSTORE_PASSWORD=changeit

# Keystore client (si mTLS requis)
# KAFKA_SSL_KEYSTORE=/app/certs/keystore.jks
# KAFKA_SSL_KEYSTORE_PASSWORD=changeit

# Certificats PEM (alternative au JKS, pour kcat/python)
# KAFKA_SSL_CAFILE=/app/certs/ca.pem
# KAFKA_SSL_CERTFILE=/app/certs/client-cert.pem
# KAFKA_SSL_KEYFILE=/app/certs/client-key.pem

# =============================================================================
# Topics
# =============================================================================
KAFKA_TOPIC_PREFIX=test-prometheus
KAFKA_NUM_TOPICS=10

# =============================================================================
# Parametres producteur
# =============================================================================
KAFKA_MESSAGES_PER_SECOND=1000
KAFKA_NUM_THREADS=5

# =============================================================================
# Parametres consommateur
# =============================================================================
KAFKA_CONSUMER_GROUP=prometheus-test-group
KAFKA_NUM_CONSUMERS=1
KAFKA_AUTO_OFFSET_RESET=earliest

# =============================================================================
# Execution
# =============================================================================
KAFKA_DURATION_MINUTES=60
KAFKA_VERBOSE=false
